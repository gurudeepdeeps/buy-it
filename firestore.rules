rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdminByUserDoc() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isAdmin() {
      return isSignedIn() && (request.auth.token.admin == true || isAdminByUserDoc());
    }

    function preservesAdminMarkers() {
      return (
        !('role' in request.resource.data)
        && !('admin' in request.resource.data)
      ) || (
        resource != null
        && request.resource.data.role == resource.data.role
        && request.resource.data.admin == resource.data.admin
      );
    }

    function validProductWrite() {
      return request.resource.data.name is string
        && request.resource.data.price is number
        && request.resource.data.category is string
        && request.resource.data.imageUrl is string
        && request.resource.data.imagePath is string
        && request.resource.data.imagePath.matches('^products/.+')
        && request.resource.data.updatedAt != null;
    }

    function validUserOrderCreate(uid) {
      return request.resource.data.uid == uid
        && request.resource.data.status is string
        && request.resource.data.totalAmount is number
        && request.resource.data.placedAt != null;
    }

    function validAddressWrite(uid) {
      return request.resource.data.uid == uid
        && request.resource.data.name is string
        && request.resource.data.phone is string
        && request.resource.data.addressLine1 is string
        && request.resource.data.city is string
        && request.resource.data.state is string
        && request.resource.data.pincode is string
        && request.resource.data.country is string;
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && validProductWrite();
      allow delete: if isAdmin();
    }

    match /accountNames/{accountNameKey} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.uid == request.auth.uid;
    }

    match /users/{uid} {
      allow read: if isSelf(uid);
      allow write: if isSelf(uid)
        && preservesAdminMarkers()
        && (
          !('accountName' in request.resource.data)
          || !('accountNameKey' in request.resource.data)
          || (
            request.resource.data.accountName is string
            && request.resource.data.accountNameKey is string
            && request.resource.data.accountName.size() > 0
            && request.resource.data.accountNameKey.size() > 0
            && getAfter(/databases/$(database)/documents/accountNames/$(request.resource.data.accountNameKey)).data.uid == uid
          )
        );

      match /cart/{itemId} {
        allow read, write: if isSelf(uid);
      }

      match /wishlist/{itemId} {
        allow read, write: if isSelf(uid);
      }

      match /orders/{orderId} {
        allow read: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
        allow create: if request.auth != null;
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }

      match /addresses/{addressId} {
        allow read: if isSelf(uid);
        allow create, update: if isSelf(uid)
          && validAddressWrite(uid);
        allow delete: if isSelf(uid);
      }
    }

    match /users/{uid}/orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if request.auth != null;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{uid}/addresses/{addressId} {
      allow read: if isSelf(uid);
      allow create, update: if isSelf(uid) && validAddressWrite(uid);
      allow delete: if isSelf(uid);
    }

    match /admin/{doc=**} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    match /categories/{categoryId} {
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }
  }
}